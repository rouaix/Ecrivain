php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value max_execution_time 1200
php_value max_input_time 1200

Options -Indexes -MultiViews
RewriteEngine On

# Block access to sensitive file types
# Exception: public/manifest.json is needed for PWA (excluded from json rule below)
<FilesMatch "\.(ini|env|txt|log|md|sql|sh|lock|phar)$">
    Require all denied
</FilesMatch>
<FilesMatch "^(?!manifest\.json$).*\.json$">
    Require all denied
</FilesMatch>

# Block ALL access to sensitive directories (fichier, dossier, et sous-chemins)
RewriteRule ^src(/.*)?$     - [F,L]
RewriteRule ^\.git(/.*)?$   - [F,L]
RewriteRule ^etc(/.*)?$     - [F,L]

# Serve static files from ../public
RewriteCond %{REQUEST_URI} ^/(.*/)?ecrivain/public/(.*)$
RewriteCond %{DOCUMENT_ROOT}/../public/%2 -f
RewriteRule ^public/(.*)$ ../public/$1 [L]

# RewriteBase /ecrivain/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule .* index.php [QSA,L]
